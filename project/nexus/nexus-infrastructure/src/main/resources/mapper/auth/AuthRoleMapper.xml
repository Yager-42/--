<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.nexus.infrastructure.dao.auth.IAuthRoleDao">

    <select id="selectByRoleCode" resultType="cn.nexus.infrastructure.dao.auth.po.AuthRolePO">
        SELECT role_id, role_code, role_name, create_time, update_time
        FROM auth_role
        WHERE role_code = #{roleCode}
    </select>

</mapper>
