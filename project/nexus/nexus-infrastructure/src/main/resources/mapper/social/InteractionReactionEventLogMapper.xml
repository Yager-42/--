<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.nexus.infrastructure.dao.social.IInteractionReactionEventLogDao">

    <resultMap id="ReactionEventLogMap" type="cn.nexus.infrastructure.dao.social.po.InteractionReactionEventLogPO">
        <id property="seq" column="seq"/>
        <result property="eventId" column="event_id"/>
        <result property="targetType" column="target_type"/>
        <result property="targetId" column="target_id"/>
        <result property="reactionType" column="reaction_type"/>
        <result property="userId" column="user_id"/>
        <result property="desiredState" column="desired_state"/>
        <result property="delta" column="delta"/>
        <result property="eventTime" column="event_time"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <insert id="insertIgnore" parameterType="cn.nexus.infrastructure.dao.social.po.InteractionReactionEventLogPO">
        INSERT INTO interaction_reaction_event_log(
            event_id,
            target_type,
            target_id,
            reaction_type,
            user_id,
            desired_state,
            delta,
            event_time,
            create_time
        )
        VALUES(
            #{eventId},
            #{targetType},
            #{targetId},
            #{reactionType},
            #{userId},
            #{desiredState},
            #{delta},
            #{eventTime},
            NOW()
        )
        ON DUPLICATE KEY UPDATE event_id = event_id
    </insert>

    <select id="selectPage" resultMap="ReactionEventLogMap">
        SELECT seq,
               event_id,
               target_type,
               target_id,
               reaction_type,
               user_id,
               desired_state,
               delta,
               event_time,
               create_time
        FROM interaction_reaction_event_log
        WHERE target_type = #{targetType}
          AND reaction_type = #{reactionType}
          AND seq &gt; #{cursor}
        ORDER BY seq ASC
        LIMIT #{limit}
    </select>
</mapper>
